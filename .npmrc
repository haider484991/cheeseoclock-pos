# Pin pnpm behavior
auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false

# Native modules need to be built per-package, not hoisted
public-hoist-pattern[]=*types*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*

# Electron native deps: keep them un-hoisted so electron-rebuild can find them
node-linker=isolated

# Use the Node-API ABI when possible (more robust across Node/Electron versions)
node-options=--max-old-space-size=4096
