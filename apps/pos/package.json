{
  "name": "@cheeseoclock/pos",
  "version": "0.3.5",
  "private": true,
  "description": "CheeseOclock POS Electron desktop app",
  "author": {
    "name": "Haider Ali",
    "email": "haider484991@gmail.com"
  },
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && rimraf node_modules/@cheeseoclock && electron-builder --win --x64",
    "build:dir": "electron-vite build && rimraf node_modules/@cheeseoclock && electron-builder --win --x64 --dir",
    "preview": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "rebuild": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "clean": "rimraf out release .turbo",
    "gen:icon": "node scripts/generate-icon.mjs"
  },
  "dependencies": {
    "@cheeseoclock/fbr-core": "workspace:*",
    "@cheeseoclock/pos-domain": "workspace:*",
    "@cheeseoclock/printer-core": "workspace:*",
    "@cheeseoclock/shared-schemas": "workspace:*",
    "@cheeseoclock/shared-types": "workspace:*",
    "@cheeseoclock/sync-core": "workspace:*",
    "@cheeseoclock/ui": "workspace:*",
    "@hookform/resolvers": "^3.9.0",
    "@node-rs/argon2": "^1.8.3",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-toast": "^1.2.1",
    "@sentry/electron": "^7.13.0",
    "@tanstack/react-query": "^5.51.23",
    "better-sqlite3": "^11.1.2",
    "clsx": "^2.1.1",
    "electron-log": "^5.1.7",
    "electron-updater": "^6.8.3",
    "kysely": "^0.27.4",
    "lucide-react": "^0.428.0",
    "pino": "^9.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.2",
    "react-router-dom": "^6.26.0",
    "tailwind-merge": "^2.5.2",
    "umzug": "^3.8.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.46.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^32.0.1",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.41",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.1",
    "vitest": "^2.0.5"
  }
}
