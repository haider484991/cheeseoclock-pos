{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node", "vite/client"],
    "outDir": "out/types-main",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@main/*": ["electron/*"],
      "electron": ["../../node_modules/electron"]
    }
  },
  "include": ["electron/**/*.ts", "electron.vite.config.ts"]
}
